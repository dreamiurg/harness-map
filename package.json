{
  "name": "harness-map",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "description": "Agent skill that generates an interactive dependency map of your AI harness",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:coverage": "c8 --include 'skills/harness-map/scripts/**' --all --check-coverage --lines 90 --functions 90 --statements 90 --branches 55 --reporter text --reporter lcov node --test tests/*.test.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "ci": "npm run lint && npm run test:coverage"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "c8": "^11.0.0"
  }
}
